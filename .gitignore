# ---- personal data — never commit these ----
# SMTP password / email login:
jobhunt_secrets.json
# your saved jobs, statuses, notes, application log:
jobhunt.db
# your live config (may hold your name + API keys):
jobhunt_config.json
# your uploaded resume(s):
resumes/
# containerized data (bind-mounted volume holding all of the above):
data/
# generated report:
jobhunt_report.html

# ---- build / run artifacts ----
.venv/
__pycache__/
*.pyc
# in-app updater state (per-install):
version.json
.backup/
.update_pending.json
.update_result.json
.deps_ok
# packaged build (attach to a GitHub Release instead):
jobhunt.zip
# screenshots / scratch images:
jobhunt-ui.png

